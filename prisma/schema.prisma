generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id                 Int       @id @default(autoincrement())
  entity_type        String    @db.VarChar(100)
  entity_id          Int
  action             String    @db.VarChar(100)
  performed_by       Int
  old_value          Json?
  new_value          Json?
  created_at         DateTime  @default(now())
  action_description String    @default("") @db.VarChar(500)
  related_user_name  String?   @db.VarChar(255)
  target_name        String?   @db.VarChar(255)
  user_name          String    @default("") @db.VarChar(255)
  user_role          UserRole?
  user               User      @relation(fields: [performed_by], references: [id], onDelete: Cascade)

  @@index([entity_type, entity_id])
  @@index([performed_by])
  @@index([action])
  @@index([created_at(sort: Desc)])
  @@index([user_role])
}

model Booking {
  id                Int               @id @default(autoincrement())
  created_by        Int
  room_id           Int
  booking_date      DateTime          @db.Date
  status            BookingStatus     @default(DRAFT)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  lesson            String?           @db.VarChar(255)
  other_requirement String?
  start_time        String            @db.VarChar(255)
  end_time          String            @db.VarChar(255)
  review_notes      String?
  hs_form_path      String?
  description       String?
  user              User              @relation(fields: [created_by], references: [id], onDelete: Cascade)
  room              Room              @relation(fields: [room_id], references: [id])
  bookingDocuments  BookingDocument[]
  invites           BookingInvite[]
  bookingItems      BookingItem[]
  messages          BookingMessage[]
  bookingTasks      BookingTask[]

  @@index([booking_date])
  @@index([created_by])
  @@index([room_id])
}

model BookingMessage {
  id         Int      @id @default(autoincrement())
  booking_id Int
  sender_id  Int
  message    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  booking    Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  sender     User     @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([sender_id])
  @@index([booking_id])
}

model BookingInvite {
  id          Int                 @id @default(autoincrement())
  booking_id  Int?
  sent_by     Int
  sent_to     Int
  status      BookingInviteStatus @default(PENDING)
  sent_at     DateTime            @default(now())
  accepted_at DateTime?
  booking     Booking?            @relation(fields: [booking_id], references: [id])
  sender      User                @relation("InviteSender", fields: [sent_by], references: [id], onDelete: Cascade)
  receiver    User                @relation("InviteReceiver", fields: [sent_to], references: [id], onDelete: Cascade)

  @@index([booking_id])
  @@index([sent_by])
  @@index([sent_to])
}

model BookingDocument {
  id            Int                 @id @default(autoincrement())
  booking_id    Int
  file_name     String              @db.VarChar(255)
  file_path     String              @db.VarChar(500)
  document_type BookingDocumentType
  created_at    DateTime            @default(now())
  booking       Booking             @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@index([booking_id])
}

model BookingItem {
  id                 Int       @id @default(autoincrement())
  booking_id         Int
  equipment_id       Int
  quantity_requested Int
  quantity_allocated Int       @default(0)
  booking            Booking   @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  equipment          Equipment @relation(fields: [equipment_id], references: [id])

  @@unique([booking_id, equipment_id])
  @@index([equipment_id])
}

model BookingTask {
  id                Int        @id @default(autoincrement())
  booking_id        Int
  assigned_to       Int
  task_type         TaskType
  status            TaskStatus @default(PENDING)
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt
  equipment_picked  String?
  missing_equipment String?
  task_notes        String?
  user              User       @relation(fields: [assigned_to], references: [id], onDelete: Cascade)
  booking           Booking    @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@index([assigned_to])
  @@index([booking_id])
}

model Equipment {
  id                 Int           @id @default(autoincrement())
  name               String        @db.VarChar(255)
  description        String?
  category           String?       @db.VarChar(255)
  quantity_available Int
  fixed_room_id      Int?
  is_active          Boolean       @default(true)
  created_at         DateTime      @default(now())
  cost               Float         @default(0)
  bookingItems       BookingItem[]
  room               Room?         @relation(fields: [fixed_room_id], references: [id])
  favourites         Favourite[]

  @@index([fixed_room_id])
}

model Favourite {
  user_id      Int
  equipment_id Int
  equipment    Equipment @relation(fields: [equipment_id], references: [id])
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, equipment_id])
}

model LoginAttempt {
  id           Int      @id @default(autoincrement())
  attempted_at DateTime @default(now()) @db.Timestamptz(6)
  email        String   @db.VarChar(320)
  ip_address   String   @db.VarChar(64)
  success      Boolean

  @@index([email, attempted_at(sort: Desc)])
  @@index([ip_address, attempted_at(sort: Desc)])
}

model PasswordSetupToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model Room {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(255)
  created_at DateTime    @default(now())
  side_rooms Int?
  type       String?     @db.VarChar(255)
  building   String?     @db.VarChar(255)
  bookings   Booking[]
  equipment  Equipment[]
}

model Session {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model User {
  id                  Int                  @id @default(autoincrement())
  first_name          String?              @db.VarChar(255)
  last_name           String?              @db.VarChar(255)
  email               String               @unique @db.VarChar(255)
  role                UserRole
  is_active           Boolean              @default(true)
  created_at          DateTime             @default(now())
  passwordHash        String
  auditLogs           AuditLog[]
  bookings            Booking[]
  sentInvites         BookingInvite[]      @relation("InviteSender")
  receivedInvites     BookingInvite[]      @relation("InviteReceiver")
  bookingMessages     BookingMessage[]
  bookingTasks        BookingTask[]
  favourites          Favourite[]
  passwordSetupTokens PasswordSetupToken[]
  sessions            Session[]
}

enum BookingDocumentType {
  SAFETY_RISK_ASSESSMENT
  OTHER
}

enum BookingStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum TaskType {
  SETUP
  STRIPDOWN
}

enum UserRole {
  ADMIN
  TECHNICIAN
  STAFF
  STUDENT
}

enum BookingInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}
