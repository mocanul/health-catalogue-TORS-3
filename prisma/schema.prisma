generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                  @id @default(autoincrement())
  first_name         String?              @db.VarChar(255)
  last_name          String?              @db.VarChar(255)
  email              String               @unique @db.VarChar(255)
  role               UserRole
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now())
  passwordHash       String
  auditLogs          AuditLog[]
  bookings           Booking[]
  PasswordSetupToken PasswordSetupToken[]
  sessions           Session[]
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  entity_type  String   @db.VarChar(100)
  entity_id    Int
  action       String   @db.VarChar(100)
  performed_by Int
  old_value    Json?
  new_value    Json?
  created_at   DateTime @default(now())
  user         User     @relation(fields: [performed_by], references: [id])

  @@index([entity_type, entity_id])
  @@index([performed_by])
}

model Booking {
  id           Int           @id @default(autoincrement())
  created_by   Int
  room_id      Int
  description  String?
  booking_date DateTime      @db.Date
  start_time   DateTime      @db.Time(6)
  end_time     DateTime      @db.Time(6)
  status       BookingStatus @default(DRAFT)
  created_at   DateTime      @default(now())
  updated_at   DateTime
  user         User          @relation(fields: [created_by], references: [id])
  room         Room          @relation(fields: [room_id], references: [id])
  bookingItems BookingItem[]

  @@index([booking_date])
  @@index([created_by])
  @@index([room_id])
}

model BookingItem {
  id                 Int       @id @default(autoincrement())
  booking_id         Int
  equipment_id       Int
  quantity_requested Int
  quantity_allocated Int       @default(0)
  booking            Booking   @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  equipment          Equipment @relation(fields: [equipment_id], references: [id])

  @@unique([booking_id, equipment_id])
  @@index([equipment_id])
}

model Equipment {
  id                 Int           @id @default(autoincrement())
  name               String        @db.VarChar(255)
  description        String?
  category           String?       @db.VarChar(255)
  quantity_available Int
  fixed_room_id      Int?
  is_active          Boolean       @default(true)
  created_at         DateTime      @default(now())
  bookingItems       BookingItem[]
  room               Room?         @relation(fields: [fixed_room_id], references: [id])

  @@index([fixed_room_id])
}

model Room {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(255)
  building   String?     @db.VarChar(255)
  created_at DateTime    @default(now())
  bookings   Booking[]
  equipment  Equipment[]
}

model LoginAttempt {
  id           Int      @id @default(autoincrement())
  attempted_at DateTime @default(now()) @db.Timestamptz(6)
  email        String   @db.VarChar(320)
  ip_address   String   @db.VarChar(64)
  success      Boolean

  @@index([email, attempted_at(sort: Desc)])
  @@index([ip_address, attempted_at(sort: Desc)])
}

model Session {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model PasswordSetupToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  User       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

enum BookingStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum UserRole {
  ADMIN
  TECHNICIAN
  STAFF
  STUDENT
}
