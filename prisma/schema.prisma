generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_log {
  id           Int      @id @default(autoincrement())
  entity_type  String   @db.VarChar(100)
  entity_id    Int
  action       String   @db.VarChar(100)
  performed_by Int
  old_value    Json?
  new_value    Json?
  created_at   DateTime @default(now())
  user         user     @relation(fields: [performed_by], references: [id])

  @@index([entity_type, entity_id])
  @@index([performed_by])
}

model booking {
  id           Int            @id @default(autoincrement())
  created_by   Int
  room_id      Int
  description  String?
  booking_date DateTime       @db.Date
  start_time   DateTime       @db.Time(6)
  end_time     DateTime       @db.Time(6)
  status       BookingStatus  @default(DRAFT)
  created_at   DateTime       @default(now())
  updated_at   DateTime
  user         user           @relation(fields: [created_by], references: [id])
  room         room           @relation(fields: [room_id], references: [id])
  booking_item booking_item[]

  @@index([booking_date])
  @@index([created_by])
  @@index([room_id])
}

model booking_item {
  id                 Int       @id @default(autoincrement())
  booking_id         Int
  equipment_id       Int
  quantity_requested Int
  quantity_allocated Int       @default(0)
  booking            booking   @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  equipment          equipment @relation(fields: [equipment_id], references: [id])

  @@unique([booking_id, equipment_id])
  @@index([equipment_id])
}

model equipment {
  id                 Int            @id @default(autoincrement())
  name               String         @db.VarChar(255)
  description        String?
  category           String?        @db.VarChar(255)
  quantity_available Int
  fixed_room_id      Int?
  is_active          Boolean        @default(true)
  created_at         DateTime       @default(now())
  booking_item       booking_item[]
  room               room?          @relation(fields: [fixed_room_id], references: [id])

  @@index([fixed_room_id])
}

model login_attempt {
  id           Int      @id @default(autoincrement())
  attempted_at DateTime @default(now()) @db.Timestamptz(6)
  email        String   @db.VarChar(320)
  ip_address   String   @db.VarChar(64)
  success      Boolean

  @@index([email, attempted_at(sort: Desc)])
  @@index([ip_address, attempted_at(sort: Desc)])
}

model room {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(255)
  building   String?     @db.VarChar(255)
  created_at DateTime    @default(now())
  booking    booking[]
  equipment  equipment[]
}

model session {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model user {
  id           Int         @id @default(autoincrement())
  first_name   String?     @db.VarChar(255)
  last_name    String?     @db.VarChar(255)
  email        String      @unique @db.VarChar(255)
  role         UserRole
  is_active    Boolean     @default(true)
  created_at   DateTime    @default(now())
  passwordHash String
  audit_log    audit_log[]
  booking      booking[]
  session      session[]
}

enum BookingStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum UserRole {
  ADMIN
  TECHNICIAN
  LECTURER
  STUDENT
}
