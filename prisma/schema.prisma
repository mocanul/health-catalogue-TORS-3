generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                  @id @default(autoincrement())
  first_name         String?              @db.VarChar(255)
  last_name          String?              @db.VarChar(255)
  email              String               @unique @db.VarChar(255)
  role               UserRole
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now())
  passwordHash       String
  auditLogs          AuditLog[]
  bookings           Booking[]
  BookingTask        BookingTask[]
  favourites         Favourite[]
  PasswordSetupToken PasswordSetupToken[]
  sessions           Session[]
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  entity_type  String   @db.VarChar(100)
  entity_id    Int
  action       String   @db.VarChar(100)
  performed_by Int
  old_value    Json?
  new_value    Json?
  created_at   DateTime @default(now())
  user         User     @relation(fields: [performed_by], references: [id])

  @@index([entity_type, entity_id])
  @@index([performed_by])
}

model Booking {
  id                Int               @id @default(autoincrement())
  created_by        Int
  room_id           Int
  booking_date      DateTime          @db.Date
  status            BookingStatus     @default(DRAFT)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  lesson            String?           @db.VarChar(255)
  other_requirement String?
  start_time        String            @db.VarChar(255)
  end_time          String            @db.VarChar(255)
  review_notes      String?
  hs_form_path      String?
  user              User              @relation(fields: [created_by], references: [id])
  room              Room              @relation(fields: [room_id], references: [id])
  BookingDocument   BookingDocument[]
  bookingItems      BookingItem[]
  BookingTask       BookingTask[]

  @@index([booking_date])
  @@index([created_by])
  @@index([room_id])
}

model BookingItem {
  id                 Int       @id @default(autoincrement())
  booking_id         Int
  equipment_id       Int
  quantity_requested Int
  quantity_allocated Int       @default(0)
  booking            Booking   @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  equipment          Equipment @relation(fields: [equipment_id], references: [id])

  @@unique([booking_id, equipment_id])
  @@index([equipment_id])
}

model Equipment {
  id                 Int           @id @default(autoincrement())
  name               String        @db.VarChar(255)
  description        String?
  category           String?       @db.VarChar(255)
  quantity_available Int
  fixed_room_id      Int?
  is_active          Boolean       @default(true)
  created_at         DateTime      @default(now())
  bookingItems       BookingItem[]
  room               Room?         @relation(fields: [fixed_room_id], references: [id])
  Favourite          Favourite[]

  @@index([fixed_room_id])
}

model Favourite {
  user_id      Int
  equipment_id Int
  equipment    Equipment @relation(fields: [equipment_id], references: [id])
  user         User      @relation(fields: [user_id], references: [id])

  @@id([user_id, equipment_id])
}

model Room {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(255)
  created_at DateTime    @default(now())
  side_rooms Int?
  type       String?     @db.VarChar(255)
  building   String?     @db.VarChar(255)
  bookings   Booking[]
  equipment  Equipment[]
}

model LoginAttempt {
  id           Int      @id @default(autoincrement())
  attempted_at DateTime @default(now()) @db.Timestamptz(6)
  email        String   @db.VarChar(320)
  ip_address   String   @db.VarChar(64)
  success      Boolean

  @@index([email, attempted_at(sort: Desc)])
  @@index([ip_address, attempted_at(sort: Desc)])
}

model Session {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model PasswordSetupToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  User       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model BookingDocument {
  id            Int                 @id @default(autoincrement())
  booking_id    Int
  file_name     String              @db.VarChar(255)
  file_path     String              @db.VarChar(500)
  document_type BookingDocumentType
  created_at    DateTime            @default(now())
  Booking       Booking             @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@index([booking_id])
}

model BookingTask {
  id          Int        @id @default(autoincrement())
  booking_id  Int
  assigned_to Int
  task_type   TaskType
  status      TaskStatus @default(PENDING)
  created_at  DateTime   @default(now())
  updated_at  DateTime
  User        User       @relation(fields: [assigned_to], references: [id])
  Booking     Booking    @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@index([assigned_to])
  @@index([booking_id])
}

enum BookingStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum UserRole {
  ADMIN
  TECHNICIAN
  STAFF
  STUDENT
}

enum BookingDocumentType {
  SAFETY_RISK_ASSESSMENT
  OTHER
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum TaskType {
  SETUP
  STRIPDOWN
}
