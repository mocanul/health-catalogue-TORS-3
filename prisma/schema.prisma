generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                   @id @default(autoincrement())
  first_name         String?               @db.VarChar(255)
  last_name          String?               @db.VarChar(255)
  email              String                @unique @db.VarChar(255)
  role               UserRole
  is_active          Boolean               @default(true)
  created_at         DateTime              @default(now())
  passwordHash       String
  auditLogs          AuditLog[]
  bookings           Booking[]
  sentInvitations    BookingCollaborator[] @relation("InvitedBy")
  collaborations     BookingCollaborator[]
  favourites         Favourite[]
  PasswordSetupToken PasswordSetupToken[]
  sessions           Session[]
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  entity_type  String   @db.VarChar(100)
  entity_id    Int
  action       String   @db.VarChar(100)
  performed_by Int
  old_value    Json?
  new_value    Json?
  created_at   DateTime @default(now())
  user         User     @relation(fields: [performed_by], references: [id])

  @@index([entity_type, entity_id])
  @@index([performed_by])
}

model Booking {
  id                Int                   @id @default(autoincrement())
  created_by        Int
  room_id           Int
  booking_date      DateTime              @db.Date
  status            BookingStatus         @default(DRAFT)
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt
  lesson            String?               @db.VarChar(255)
  other_requirement String?
  start_time        String                @db.VarChar(5)
  end_time          String                @db.VarChar(5)
  user              User                  @relation(fields: [created_by], references: [id])
  room              Room                  @relation(fields: [room_id], references: [id])
  collaborators     BookingCollaborator[]
  bookingItems      BookingItem[]

  @@index([booking_date])
  @@index([created_by])
  @@index([room_id])
}

model BookingCollaborator {
  booking_id Int
  user_id    Int
  invited_by Int
  status     CollaboratorStatus @default(PENDING)
  booking    Booking            @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  inviter    User               @relation("InvitedBy", fields: [invited_by], references: [id])
  user       User               @relation(fields: [user_id], references: [id])

  @@id([booking_id, user_id])
  @@index([user_id])
  @@index([invited_by])
}

model BookingItem {
  id                 Int       @id @default(autoincrement())
  booking_id         Int
  equipment_id       Int
  quantity_requested Int
  quantity_allocated Int       @default(0)
  booking            Booking   @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  equipment          Equipment @relation(fields: [equipment_id], references: [id])

  @@unique([booking_id, equipment_id])
  @@index([equipment_id])
}

model Equipment {
  id                 Int           @id @default(autoincrement())
  name               String        @db.VarChar(255)
  description        String?
  category           String?       @db.VarChar(255)
  quantity_available Int
  fixed_room_id      Int?
  is_active          Boolean       @default(true)
  created_at         DateTime      @default(now())
  bookingItems       BookingItem[]
  room               Room?         @relation(fields: [fixed_room_id], references: [id])
  Favourite          Favourite[]

  @@index([fixed_room_id])
}

model Favourite {
  user_id      Int
  equipment_id Int
  equipment    Equipment @relation(fields: [equipment_id], references: [id])
  user         User      @relation(fields: [user_id], references: [id])

  @@id([user_id, equipment_id])
}

model Room {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(255)
  created_at DateTime    @default(now())
  side_rooms Int?
  type       String?     @db.VarChar(255)
  bookings   Booking[]
  equipment  Equipment[]
}

model LoginAttempt {
  id           Int      @id @default(autoincrement())
  attempted_at DateTime @default(now()) @db.Timestamptz(6)
  email        String   @db.VarChar(320)
  ip_address   String   @db.VarChar(64)
  success      Boolean

  @@index([email, attempted_at(sort: Desc)])
  @@index([ip_address, attempted_at(sort: Desc)])
}

model Session {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model PasswordSetupToken {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  User       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([user_id])
}

model BookingCollaborator {
  booking_id                                Int
  user_id                                   Int
  invited_by                                Int
  status                                    CollaboratorStatus @default(PENDING)
  Booking                                   Booking            @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  User_BookingCollaborator_invited_byToUser User               @relation("BookingCollaborator_invited_byToUser", fields: [invited_by], references: [id])
  User_BookingCollaborator_user_idToUser    User               @relation("BookingCollaborator_user_idToUser", fields: [user_id], references: [id])

  @@id([booking_id, user_id])
  @@index([invited_by])
  @@index([user_id])
}

model Favourite {
  user_id      Int
  equipment_id Int
  Equipment    Equipment @relation(fields: [equipment_id], references: [id])
  User         User      @relation(fields: [user_id], references: [id])

  @@id([user_id, equipment_id])
}

enum BookingStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum UserRole {
  ADMIN
  TECHNICIAN
  STAFF
  STUDENT
}

enum CollaboratorStatus {
  PENDING
  ACCEPTED
  REJECTED
}
